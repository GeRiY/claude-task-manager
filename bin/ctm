#!/usr/bin/env bash
#
# ctm — the claude-task-manager command-line entry point.
#
# This file typically runs as a SYMLINK from a directory on PATH (e.g. /usr/local/bin/ctm or
# ~/.local/bin/ctm) — install.sh registers it automatically. Callable from any project
# directory, no cd/absolute path needed.
#
# Usage:
#   ctm init [project-id] [label]   Install the CURRENT directory (or its git root)
#   ctm list                        Registered projects
#   ctm rm <id> [--force]           Remove a registered project (data + wrapper) — asks first
#   ctm wrapper <id>                Print a project's generated wrapper task.sh
#   ctm feedback show [n]           Show the global cross-project feedback log (agents file
#                                    into it via `task.sh feedback`, from any installed project)
#   ctm feedback add <cause> <parameter> <explanation>
#                                    File an entry yourself (same log, actor recorded as "cli")
#   ctm agent add <name> [desc]     Create a custom ("tm-<name>") teammate definition
#   ctm up [port]                   Start/check the board with docker; if running, only
#                                    reconciles; if a port is given, sets it (writes .env)
#                                    and restarts the container. Reports a busy port before
#                                    calling docker at all.
#   ctm down                        Stop the board.
#   ctm autostart on|off            Auto-start the container on Docker/machine restart
#                                    (docker restart-policy) — sets and applies it.
#   ctm fix-perms                   Reclaim data/ ownership from a root-running container
#                                    (native Linux Docker) — chowns via the container root.

set -euo pipefail

# Resolve the real file behind the symlink (portable, works on macOS too — BSD readlink
# doesn't support -f).
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"

die() { echo "error: $*" >&2; exit 1; }

# shellcheck source=engine/check-update.sh
source "$ROOT_DIR/engine/check-update.sh"
check_for_updates "$ROOT_DIR"

# docker-compose.yml interpolates the .env CTM_PORT value from the project root into the
# ports/command fields — this is where we write the desired port, if the caller gave one.
set_env_var() {
  local file="$1" key="$2" value="$3" tmp
  tmp="$(mktemp)"
  [[ -f "$file" ]] && grep -v "^${key}=" "$file" > "$tmp" || true
  echo "${key}=${value}" >> "$tmp"
  mv "$tmp" "$file"
}
# Persist the host user's UID/GID into .env so docker-compose.yml's `user:` runs the
# container AS the host user — this keeps data/ (tasks.json etc.) owned by the host user
# instead of root. Called before every `docker compose up`. See docker-compose.yml.
set_host_uid_gid() {
  set_env_var "$ROOT_DIR/.env" "CTM_UID" "$(id -u)"
  set_env_var "$ROOT_DIR/.env" "CTM_GID" "$(id -g)"
}
current_port() {
  # `|| true` is REQUIRED: under `set -euo pipefail`, if .env has no CTM_PORT= line
  # (first run / missing .env) grep exits 1, the pipeline fails, and the `$(current_port)`
  # substitution in `up` would silently kill the whole script before `docker compose up`.
  grep '^CTM_PORT=' "$ROOT_DIR/.env" 2>/dev/null | head -1 | cut -d= -f2 || true
}

# True if OUR OWN container (claude-task-manager) is already running and already listening
# on this port — in that case there's no conflict, docker compose will just reconcile.
our_container_already_on_port() {
  local port="$1"
  docker ps --filter "name=^claude-task-manager$" --format '{{.Ports}}' 2>/dev/null \
    | grep -q "127.0.0.1:${port}->"
}

# If the requested port is already taken by a DIFFERENT process, fail clearly before even
# calling docker compose (its own error message is less helpful here).
check_port_free() {
  local port="$1"
  our_container_already_on_port "$port" && return 0
  if command -v lsof >/dev/null 2>&1 && lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
    die "port $port is already in use (by another process) — pick a different one: ctm up <other-port>"
  fi
}

cmd="${1:-help}"; shift || true

case "$cmd" in
  init)
    "$ROOT_DIR/install.sh" "$(pwd)" "$@"
    ;;
  list|ls)
    "$ROOT_DIR/engine/projects.sh" list
    ;;
  rm|remove)
    id="" force=0
    for a in "$@"; do
      case "$a" in
        --force|-y|--yes) force=1 ;;
        *) id="$a" ;;
      esac
    done
    [[ -n "$id" ]] || die "usage: ctm rm <id> [--force]"
    if [[ "$force" != "1" ]]; then
      if [[ ! -t 0 ]]; then
        die "project \"$id\" not removed — non-interactive session, pass --force to confirm"
      fi
      reply=""
      read -r -p "Remove project \"$id\" (data + wrapper, cannot be undone)? [y/N] " reply || reply="n"
      [[ "$reply" =~ ^[Yy]$ ]] || { echo "cancelled"; exit 0; }
    fi
    "$ROOT_DIR/engine/projects.sh" rm "$id"
    ;;
  wrapper)
    "$ROOT_DIR/engine/projects.sh" wrapper "$@"
    ;;
  feedback)
    # shellcheck source=engine/feedback.sh
    source "$ROOT_DIR/engine/feedback.sh"
    sub="${1:-show}"
    case "$sub" in
      add)
        shift
        [[ $# -ge 3 ]] || die 'usage: ctm feedback add "<cause>" "<parameter>" "<explanation>"'
        log_feedback "$1" "$2" "$3" "cli" "-" || die "could not write feedback (lock contention?)"
        echo "logged: $FEEDBACK_FILE"
        ;;
      show)
        shift
        show_feedback "${1:-}"
        ;;
      *) die "usage: ctm feedback {add \"<cause>\" \"<parameter>\" \"<explanation>\" | show [n]}" ;;
    esac
    ;;
  agent)
    sub="${1:-}"; shift || true
    case "$sub" in
      add) "$ROOT_DIR/bin/add-agent.sh" "$(pwd)" "$@" ;;
      tools)
        # Read AND write the per-agent tools allow-list that `ctm init` bakes in (repo config
        # + this project's .claude/agent-tools.json override). Mirrors `ctm agent block`:
        # an omitted [name] means "default", i.e. every agent in this project at once.
        # shellcheck source=engine/agent-tools.sh
        source "$ROOT_DIR/engine/agent-tools.sh"
        proj="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
        tsub="${1:-}"
        case "$tsub" in
          set|add|rm)
            shift
            # ctm agent tools set <list>          -> project-wide default
            # ctm agent tools set <name> <list>   -> one agent
            if [[ $# -ge 2 ]]; then
              tname="$1"; shift; tlist="$*"
            elif [[ $# -eq 1 ]]; then
              tname="default"; tlist="$1"
            else
              die "usage: ctm agent tools $tsub [name] <tool,...>"
            fi
            case "$tsub" in
              set) set_agent_tools "$proj" "$tname" "$tlist" ;;
              add) add_agent_tools "$proj" "$tname" "$tlist" ;;
              rm)  rm_agent_tools  "$proj" "$tname" "$tlist" ;;
            esac
            ;;
          unset)
            shift
            unset_agent_tools "$proj" "${1:-default}"
            ;;
          show)
            shift
            print_agent_tools "$proj" "${1:-}" | column -t -s $'\t'
            ;;
          # No subcommand: `ctm agent tools` / `ctm agent tools <name>` stay a plain listing,
          # as before.
          *) print_agent_tools "$proj" "${1:-}" | column -t -s $'\t' ;;
        esac
        ;;
      block)
        # shellcheck source=engine/agent-block.sh
        source "$ROOT_DIR/engine/agent-block.sh"
        proj="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
        bsub="${1:-}"; shift || true
        case "$bsub" in
          set)
            # ctm agent block set <file>            -> sets the default block
            # ctm agent block set <name> <file>      -> sets a per-agent block
            if [[ $# -ge 2 ]]; then
              bname="$1"; bfile="$2"
            elif [[ $# -eq 1 ]]; then
              bname="default"; bfile="$1"
            else
              die "usage: ctm agent block set [name] <file>"
            fi
            set_agent_block "$proj" "$bname" "$bfile"
            ;;
          unset)
            unset_agent_block "$proj" "${1:-default}"
            ;;
          show|"")
            print_agent_block "$proj" "${1:-}"
            ;;
          *) die "usage: ctm agent block {set [name] <file> | unset [name] | show [name]}" ;;
        esac
        ;;
      *) die "usage: ctm agent add <name> [description]  |  ctm agent tools {show|set|add|rm|unset} [name] [tools]  |  ctm agent block {set|unset|show}" ;;
    esac
    ;;
  up)
    port="${1:-$(current_port)}"
    port="${port:-3333}"
    [[ "$port" =~ ^[0-9]+$ ]] || die "invalid port: $port"
    check_port_free "$port"
    set_env_var "$ROOT_DIR/.env" "CTM_PORT" "$port"
    set_host_uid_gid
    # `docker compose up -d` is itself idempotent: if the container isn't running, it starts
    # it; if it's running and the config (e.g. port) changed, it's automatically recreated
    # with the new setting; if it's running and nothing changed, it does nothing.
    (cd "$ROOT_DIR" && docker compose up -d --build)
    echo "board: http://localhost:$(current_port)/"
    ;;
  down)
    (cd "$ROOT_DIR" && docker compose down)
    ;;
  autostart)
    mode="${1:-}"
    case "$mode" in
      on)  set_env_var "$ROOT_DIR/.env" "CTM_RESTART" "unless-stopped" ;;
      off) set_env_var "$ROOT_DIR/.env" "CTM_RESTART" "no" ;;
      *) die "usage: ctm autostart on|off" ;;
    esac
    set_host_uid_gid
    (cd "$ROOT_DIR" && docker compose up -d --build)
    echo "autostart: $mode (restart-policy: $(grep '^CTM_RESTART=' "$ROOT_DIR/.env" | cut -d= -f2))"
    ;;
  fix-perms)
    # Reclaim ownership of data/ files that a previously root-running container left as
    # root:root (native Linux Docker). Chowns THROUGH the container's root (docker exec -u 0)
    # so no host `sudo` is needed; falls back to a host chown if the container isn't running.
    uid="$(id -u)"; gid="$(id -g)"
    if docker ps --filter "name=^claude-task-manager$" --format '{{.Names}}' 2>/dev/null | grep -q .; then
      docker exec -u 0 claude-task-manager chown -R "${uid}:${gid}" /app/data \
        && echo "fixed: data/ ownership → ${uid}:${gid} (via container root)"
    elif chown -R "${uid}:${gid}" "$ROOT_DIR/data" 2>/dev/null; then
      echo "fixed: data/ ownership → ${uid}:${gid} (host chown)"
    else
      die "container not running and host chown failed — start it (ctm up) then rerun, or: sudo chown -R ${uid}:${gid} \"$ROOT_DIR/data\""
    fi
    ;;
  help|-h|--help|"")
    cat <<'EOF'
ctm — claude-task-manager CLI

  ctm init [project-id] [label] [--force]
                                   Register the CURRENT directory (or its git root) as a
                                   project + install .claude/skills/task-manager/ (task.sh
                                   wrapper + SKILL.md + ctm-* agents + hooks + allowlist).
                                   Docker NOT required. Prompts before overwriting an
                                   existing file (--force / -y skips the prompt).
  ctm list                        List registered projects.
  ctm rm <id> [--force]           Remove a registered project (data + wrapper). Asks for
                                   confirmation first (or requires --force non-interactively).
  ctm wrapper <id>                Print a project's generated wrapper task.sh.
  ctm feedback show [n]           Show the GLOBAL, cross-project feedback log — bugs/
                                   observations agents filed about the tool itself via
                                   `task.sh feedback` (any installed project, any agent).
                                   Omit n for everything, or pass n for just the last n lines.
  ctm feedback add <cause> <parameter> <explanation>
                                   File an entry yourself, same log (actor recorded as "cli").
  ctm agent add <name> [desc]     Create a custom teammate definition in the CURRENT
                                   (already "ctm init"-ed) project — always named "tm-<name>".
  ctm agent tools [show] [name]   Show the effective per-agent tools allow-list baked in at
                                   init (config: templates/agent-tools.json; project override:
                                   .claude/agent-tools.json). No name = the whole roster.
  ctm agent tools set [name] <tools>
                                   Set this PROJECT's allow-list. Omit name to set it for every
                                   agent at once; pass an agent name (e.g. ctm-be-medior, tm-foo)
                                   for just that one. Comma-separated, e.g. "Read, Bash, Edit".
  ctm agent tools add [name] <tools>
  ctm agent tools rm  [name] <tools>
                                   Add to / remove from the current effective list. A small
                                   mandatory core (Bash, Read, SendMessage) cannot be removed —
                                   without it an agent cannot run task.sh at all.
  ctm agent tools unset [name]    Drop the project override, falling back to the built-in list.
  ctm agent block set [name] <file>
                                   Upload a Markdown file as a "project block" appended to a
                                   generated agent's body at init. Omit name to set the
                                   default block (used when no per-agent block matches);
                                   pass an agent name (e.g. ctm-be-medior, tm-foo) for a
                                   per-agent block. Stored in .claude/agent-blocks/.
  ctm agent block unset [name]    Remove a project block override (default if name omitted).
  ctm agent block show [name]     Show the effective block(s) that `ctm init` would bake in.
  ctm up [port]                   Check/start the board with docker. Starts it if not
                                   running; does nothing if already running; if you also give
                                   a port, sets it and restarts if needed.
  ctm down                        Stop the board.
  ctm autostart on|off            Auto-start the container on Docker/machine restart.
  ctm fix-perms                   Reclaim ownership of data/ files a root-running container
                                   left as root:root (native Linux Docker). No sudo needed
                                   while the container is up.
EOF
    ;;
  *) die "unknown command: $cmd (help: ctm help)" ;;
esac
